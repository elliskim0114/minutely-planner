{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/send-daily-summary",
      "schedule": "0 8 * * *"
    }
  ]
}
